config openmesh 'agent'
	option enabled '0'
	option controller 'http://127.0.0.1:8080'
	option token 'dev-token'
	option node_id ''
	option config_path '/etc/openmesh/agent.json'
	option wg_config '/etc/wireguard/openmesh.conf'
	option wg_interface 'openmesh'
	option wg_address ''
	option wg_mtu '1280'
	option interval '30s'
	option sync_command ''
