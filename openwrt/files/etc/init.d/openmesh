#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

CONFIG_FILE=/etc/config/openmesh

start_service() {
	config_load openmesh
	config_get_bool enabled agent enabled 0
	[ "$enabled" = "1" ] || return 0

	config_get controller agent controller
	config_get token agent token
	config_get node_id agent node_id
	config_get config_path agent config_path /etc/openmesh/agent.json
	config_get wg_config agent wg_config /etc/wireguard/openmesh.conf
	config_get interval agent interval 30s
	config_get sync_command agent sync_command

	mkdir -p /etc/openmesh
	openmesh agent save-config \
		--controller "$controller" \
		--token "$token" \
		--node-id "$node_id" \
		--config "$config_path" \
		--wg-config "$wg_config" \
		--sync-command "$sync_command"

	procd_open_instance
	procd_set_param command /usr/bin/openmesh agent daemon --config "$config_path" --interval "$interval"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	restart
}
