#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

CONFIG_FILE=/etc/config/openmesh

load_agent_config() {
	config_load openmesh
	config_get_bool enabled agent enabled 0
	config_get controller agent controller
	config_get token agent token
	config_get node_id agent node_id
	config_get config_path agent config_path /etc/openmesh/agent.json
	config_get wg_config agent wg_config /etc/wireguard/openmesh.conf
	config_get wg_interface agent wg_interface openmesh
	config_get wg_address agent wg_address
	config_get wg_mtu agent wg_mtu 1280
	config_get interval agent interval 30s
	config_get sync_command agent sync_command
}

write_agent_config() {
	mkdir -p /etc/openmesh /etc/wireguard
	openmesh agent save-config \
		--controller "$controller" \
		--token "$token" \
		--node-id "$node_id" \
		--config "$config_path" \
		--wg-config "$wg_config" \
		--wg-interface "$wg_interface" \
		--wg-address "$wg_address" \
		--wg-mtu "$wg_mtu" \
		--sync-command "$sync_command"
}

start_service() {
	load_agent_config
	[ "$enabled" = "1" ] || return 0
	write_agent_config

	# Bring the interface up once, then keep syncing config in the background.
	openmesh agent up --config "$config_path"

	procd_open_instance
	procd_set_param command /usr/bin/openmesh agent daemon --config "$config_path" --interval "$interval"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	load_agent_config
	[ -n "$config_path" ] || config_path=/etc/openmesh/agent.json
	if [ -f "$config_path" ]; then
		openmesh agent down --config "$config_path" || true
	fi
}

reload_service() {
	load_agent_config
	[ "$enabled" = "1" ] || return 0
	write_agent_config
	openmesh agent up --config "$config_path"
}
